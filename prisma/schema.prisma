generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cliente {
  id                String    @id @default(cuid())
  nome              String
  cpf               String?
  cnpj              String?
  inscricaoEstadual String?
  indicadorIE       String    @default("9") // 1=Contribuinte, 2=Isento, 9=Não contribuinte
  email             String?
  telefone          String?
  endereco          String?
  numero            String?
  bairro            String?
  cidade            String?
  estado            String?
  codigoIbge        String?   // código IBGE da cidade (7 dígitos) para NFe
  cep               String?
  ultimaCompra      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  pedidos           Pedido[]
  visitas           Visita[]
}

model Produto {
  id               String        @id @default(cuid())
  nome             String
  descricao        String?
  tipo             String        @default("PRODUTO") // PRODUTO ou SERVICO
  peso             Float         // peso em kg
  precoVenda       Float
  custoProducao    Float         @default(0)
  duracaoMedia     Int?          // duração média em dias (para pós-venda)
  unidade          String        @default("un") // un, L, kg, etc.
  unidadesPorCaixa Int?          // quantas unidades cabem por caixa
  caixaDimensoes   String?       // dimensões da caixa ex: "25x30x20"
  // Dados fiscais (NFe)
  ncm              String?       // código NCM (8 dígitos)
  origem           String        @default("0") // 0-8, 0 = nacional
  cest             String?       // código CEST (opcional)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  itensPedido      ItemPedido[]
}

model Pedido {
  id              String       @id @default(cuid())
  numero          Int          @unique @default(autoincrement())
  clienteId       String
  cliente         Cliente      @relation(fields: [clienteId], references: [id])
  fase            FasePedido   @default(PEDIDO)
  valorProdutos   Float        @default(0)
  valorFrete      Float        @default(0)
  desconto        Float        @default(0)
  valorTotal      Float        @default(0)
  pesoTotal       Float        @default(0)
  volumes         Int          @default(1)
  observacoes     String?
  condicaoPagamento String?    // ex: "28" ou "28/56/84" — dias corridos
  notaFiscal      String?
  boleto          String?
  dataEnvio       DateTime?
  dataRecebimento DateTime?
  // NFe
  nfeStatus       String?      // null, "processando", "autorizada", "cancelada", "erro"
  nfeRef          String?      @unique // nossa referência enviada para Focus NFe
  nfeNumero       Int?
  nfeSerie        Int?
  nfeChave        String?
  nfeDataEmissao  DateTime?
  nfeMensagem     String?      // mensagem de erro ou justificativa de cancelamento
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  itens           ItemPedido[]
  anexos          Anexo[]
}

model Anexo {
  id        String   @id @default(cuid())
  pedidoId  String
  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  nome      String
  tipo      String   // mime type
  tamanho   Int      // bytes
  dados     String   // base64 encoded file
  fase      String   // fase em que foi anexado
  createdAt DateTime @default(now())
}

enum FasePedido {
  PEDIDO
  ORCAMENTO
  APROVADO
  PRODUCAO
  ENVIO
  RECEBIDO
}

model ItemPedido {
  id         String  @id @default(cuid())
  pedidoId   String
  pedido     Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId  String
  produto    Produto @relation(fields: [produtoId], references: [id])
  quantidade Int
  pesoTotal  Float   // quantidade * peso do produto
  precoUnit  Float
  subtotal   Float
}

model Visita {
  id          String         @id @default(cuid())
  clienteId   String
  cliente     Cliente        @relation(fields: [clienteId], references: [id])
  data        DateTime
  observacoes String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  anexos      AnexoVisita[]
}

model AnexoVisita {
  id        String   @id @default(cuid())
  visitaId  String
  visita    Visita   @relation(fields: [visitaId], references: [id], onDelete: Cascade)
  nome      String
  tipo      String   // mime type
  tamanho   Int      // bytes
  dados     String   // base64 encoded file
  createdAt DateTime @default(now())
}

model Despesa {
  id        String         @id @default(cuid())
  descricao String
  valor     Float
  categoria CategoriaDespesa
  data      DateTime
  mes       Int            // 1-12
  ano       Int
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

enum CategoriaDespesa {
  BONIFICACAO
  COMBUSTIVEL
  HOSPEDAGEM
  IMPOSTOS
  SISTEMAS
  OUTROS
}
